# ===========================================
# Savebot — Node.js Telegram Video Downloader
# ===========================================

# Telegram Bot
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij
BOT_USERNAME=VFetchBot

# Admin (comma-separated Telegram user IDs)
ADMIN_USER_IDS=123456789,987654321

# VIP users (comma-separated Telegram user IDs) — increased playlist limits
VIP_USER_IDS=

# yt-dlp Configuration
YTDLP_PATH=/usr/local/bin/yt-dlp
YTDLP_IMPERSONATE=chrome
YTDLP_PROXY=

# Per-platform proxies (optional)
YTDLP_PROXY_YOUTUBE=
YTDLP_PROXY_INSTAGRAM=
YTDLP_PROXY_TIKTOK=
YTDLP_PROXY_VK=
YTDLP_PROXY_YANDEX=

# Cookie Storage Path (shared between bot and microservice)
COOKIES_DIR=./cookies
INSTAGRAM_COOKIES_MAX_AGE_SECONDS=86400

# Video Download Limit
MAX_VIDEO_SIZE_BYTES=104857600

# Yandex Music playlist limits
MAX_PLAYLIST_TRACKS=20
VIP_MAX_PLAYLIST_TRACKS=100

# Temporary Processing Directories
TEMP_DIR=./tmp

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Download Processing Timeout (seconds)
PROCESSING_TIMEOUT_SECONDS=900

# ===========================================
# Cookie Getter Microservice Configuration
# ===========================================

# Instagram Credentials required for the headless scraper
INSTAGRAM_LOGIN=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# How often the cookie getter runs to harvest a fresh session (minutes)
COOKIE_REFRESH_INTERVAL_MINUTES=15
